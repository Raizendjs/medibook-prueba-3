---
import Button from './Button.astro';
import { NAV_LINKS, BRAND_NAME, BRAND_LOGO_TEXT } from '../config';
import { resolvePath } from '../utils/navigation';

const user = Astro.locals.user;
const userName =
  user?.user_metadata?.full_name ??
  user?.user_metadata?.name ??
  user?.email ??
  "Usuario";
const userAvatar = user?.user_metadata?.avatar_url ?? user?.user_metadata?.picture ?? null;
const userInitial = userName.charAt(0).toUpperCase();

// Rutas del submenu de usuario (dashboard)
const USER_MENU_LINKS = [
  {
    href: '/',
    label: 'Inicio',
    icon: 'home',
  },
  {
    href: '/dashboard/',
    label: 'Dashboard',
    icon: 'layout-dashboard',
  },
  {
    href: '/mis-propiedades/',
    label: 'Mis propiedades',
    icon: 'building',
  },
  {
    href: '/mis-reservas/',
    label: 'Mis reservas',
    icon: 'calendar-check',
  },
  {
    href: '/mis-reservas-host/',
    label: 'Mis reservas (Host)',
    icon: 'calendar-check',
  },
  {
    href: '/listings/',
    label: 'Listings',
    icon: 'list',
  },
];

// Iconos minimalistas (stroke, estilo lucide) para el submenu de usuario
const ICONS: Record<string, string> = {
  home: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7"/><path d="M5 10v10a1 1 0 0 0 1 1h3v-6h6v6h3a1 1 0 0 0 1-1V10"/></svg>`,
  'layout-dashboard': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>`,
  building: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M12 6h.01M16 6h.01M8 10h.01M12 10h.01M16 10h.01M8 14h.01M12 14h.01M16 14h.01"/></svg>`,
  'calendar-check': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>`,
  list: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h13M8 12h13M8 18h13"/><path d="M3 6h.01M3 12h.01M3 18h.01"/></svg>`,
  'log-out': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>`,
};
---

<header
  id="main-header"
  class="fixed top-0 z-[90] w-full transition-all duration-300 border-x-0 border-t-0 rounded-none pointer-events-auto"
>
  
  <div class="w-full px-4 sm:px-6 lg:px-8 ">
    <div class="flex items-center  justify-between h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={resolvePath('/')} class="flex items-center gap-2 group">
          <div class="w-8 h-8 bg-blue-800 dark:bg-blue-800 rounded-lg flex items-center justify-center transition-transform group-hover:scale-105">
            <span class="text-white font-bold text-xl leading-none">{BRAND_LOGO_TEXT}</span>
          </div>
          <span class="font-heading font-bold text-xl text-slate-900 dark:text-white transition-colors">{BRAND_NAME}</span>
        </a>
      </div>

      <!-- CTA Buttons & Theme Toggle (Desktop) -->
      <div class="hidden md:flex items-center gap-4">
        <!-- Search Button -->
        <button 
          onclick="window.toggleCommandPalette()"
          class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white bg-slate-100 dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 transition-colors"
          aria-label="Search"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          <span>Search</span>
          <kbd class="hidden lg:inline-flex h-5 items-center gap-1 rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 px-1.5 font-mono text-[10px] font-medium text-slate-400">
            <span class="text-xs">⌘</span>K
          </kbd>
        </button>

        <!-- Theme Toggle -->
        <button id="theme-toggle" data-theme-toggle type="button" class="p-2 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg text-sm transition-colors" aria-label="Toggle theme">
          <svg data-theme-dark-icon class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
          <svg data-theme-light-icon class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
        </button>

        {user ? (
          <div class="relative group">
            <button class="flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
              {userAvatar ? (
                <img
                  src={userAvatar}
                  alt={userName}
                  class="w-7 h-7 rounded-full object-cover"
                />
              ) : (
                <span class="w-7 h-7 rounded-full bg-blue-800 text-white text-xs font-semibold flex items-center justify-center">
                  {userInitial}
                </span>
              )}
              <span class="text-sm font-medium text-slate-700 dark:text-slate-200 max-w-[120px] truncate">
                {userName}
              </span>
              <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0" title="Activo"></span>
            </button>

            <div
              class="absolute right-0 top-full mt-1 z-50 hidden min-w-[220px]
              rounded-lg border border-slate-200 dark:border-slate-700
              bg-white dark:bg-slate-900 shadow-lg group-hover:block py-1"
            >
              {USER_MENU_LINKS.map(link => (
                <a href={resolvePath(link.href)}
                  class="flex items-center gap-2.5 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800"
                >
                  <span class="text-slate-400 dark:text-slate-500 [&>svg]:w-4 [&>svg]:h-4" set:html={ICONS[link.icon]} />
                  {link.label}
                </a>
              ))}

              <div class="my-1 border-t border-slate-200 dark:border-slate-700"></div>

              <form method="POST" action="/api/logout/" class="block">
                <button
                  type="submit"
                  class="w-full flex items-center gap-2.5 text-left px-4 py-2 text-sm text-red-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-b-lg"
                >
                  <span class="[&>svg]:w-4 [&>svg]:h-4" set:html={ICONS['log-out']} />
                  Cerrar sesión
                </button>
              </form>
            </div>
          </div>
        ) : (
          <>
            <a href={resolvePath('/login/')} class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">
              Sign in
            </a>
            <Button href={resolvePath('/signup/')} variant="primary" size="sm">Get Started</Button>
          </>
        )}
      </div>

      <!-- Mobile menu button & Theme toggle -->
      <div class="md:hidden flex items-center gap-2">
        <button onclick="window.toggleCommandPalette()" class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none rounded-lg text-sm" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        </button>

        <button id="mobile-theme-toggle" data-theme-toggle type="button" class="p-2 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none rounded-lg text-sm" aria-label="Toggle theme">
          <svg data-theme-dark-icon class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
          <svg data-theme-light-icon class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
        </button>
        
        <button id="mobile-menu-btn" class="p-2 rounded-md text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none">
          <span class="sr-only">Open main menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
  
      {NAV_LINKS.map(link => (
        link.children ? (
          <details class="group rounded-md">
            
            <summary class="flex items-center justify-between cursor-pointer px-3 py-2 text-base font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md list-none">
              {link.label}
  
              <svg
                class="w-4 h-4 transition-transform group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
  
            <div class="ml-4 mt-1 border-l border-slate-200 dark:border-slate-700">
              {link.children.map(child => (
                
                <a href={resolvePath(child.href)}
                  class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400"
                >
                  {child.label}
                </a>
              ))}
            </div>
  
          </details>
        ) : (
          
        <a href={resolvePath(link.href)}
            class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-300 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-slate-50 dark:hover:bg-slate-800"
          >
            {link.label}
          </a>
        )
      ))}
  
      <div class="mt-4 pt-4 border-t border-slate-200 dark:border-slate-800 flex flex-col gap-2">
        {user ? (
          <>
            <div class="flex items-center gap-3 px-3 py-2">
              {userAvatar ? (
                <img src={userAvatar} alt={userName} class="w-9 h-9 rounded-full object-cover" />
              ) : (
                <span class="w-9 h-9 rounded-full bg-blue-800 text-white text-sm font-semibold flex items-center justify-center">
                  {userInitial}
                </span>
              )}
              <div class="flex flex-col">
                <span class="text-sm font-medium text-slate-900 dark:text-white truncate max-w-[180px]">
                  {userName}
                </span>
                <span class="text-xs text-emerald-500 flex items-center gap-1">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  Activo
                </span>
              </div>
            </div>

            {USER_MENU_LINKS.map(link => (
              <a href={resolvePath(link.href)}
                class="flex items-center gap-2.5 px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800"
              >
                <span class="text-slate-400 dark:text-slate-500 [&>svg]:w-[18px] [&>svg]:h-[18px]" set:html={ICONS[link.icon]} />
                {link.label}
              </a>
            ))}

            <div class="my-1 border-t border-slate-200 dark:border-slate-800"></div>

            <form method="POST" action="/api/logout/">
              <button
                type="submit"
                class="w-full flex items-center gap-2.5 text-left px-3 py-2 rounded-md text-base font-medium text-red-500 hover:bg-slate-50 dark:hover:bg-slate-800"
              >
                <span class="[&>svg]:w-[18px] [&>svg]:h-[18px]" set:html={ICONS['log-out']} />
                Cerrar sesión
              </button>
            </form>
          </>
        ) : (
          <>
            <a href={resolvePath('/login/')} class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800">
              Sign in
            </a>
            <Button href={resolvePath('/signup/')} variant="primary" class="w-full text-center">
              Get Started
            </Button>
          </>
        )}
      </div>
  
    </div>
  </div>
</header>

<script>
  function setupTheme() {
    const storedTheme = localStorage.getItem('theme');
    if (storedTheme === 'dark' || storedTheme === 'light') {
      document.documentElement.classList.toggle('dark', storedTheme === 'dark');
    }

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        button.setAttribute('aria-pressed', String(isDark));
        button.querySelector('[data-theme-dark-icon]')?.classList.toggle('hidden', isDark);
        button.querySelector('[data-theme-light-icon]')?.classList.toggle('hidden', !isDark);
      });
    }

    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    }

    updateIcons();

    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      if (button.dataset.themeBound === 'true') return;
      button.dataset.themeBound = 'true';
      button.addEventListener('click', toggleTheme);
    });
  }

  function setupMobileMenu() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      // Use a fresh button to avoid multiple listeners
      const newBtn = mobileMenuBtn.cloneNode(true);
      mobileMenuBtn.parentNode?.replaceChild(newBtn, mobileMenuBtn);
      
      newBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
    }
  }

  // Run on initial load
  setupTheme();
  setupMobileMenu();
  
  // Run on View Transitions page changes
  document.addEventListener('astro:page-load', () => {
    setupTheme();
    setupMobileMenu();
  });

  function initHeaderScroll() {
    const header = document.getElementById('main-header');
    if (!header) return;

    function handleScroll() {
      const isTop = window.scrollY === 0;

      if (isTop) {
        header.classList.add('bg-transparent');
        header.classList.remove(
          'backdrop-blur-md',
          'bg-white/70',
          'dark:bg-slate-900/70',
          'shadow-sm'
        );
      } else {
        header.classList.remove('bg-transparent');
        header.classList.add(
          'backdrop-blur-md',
          'bg-white/70',
          'dark:bg-slate-900/70',
          'shadow-sm'
        );
      }
    }

    // ❗ IMPORTANTE: evitar múltiples listeners
    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll);

    handleScroll();
  }

  // Primera carga
  initHeaderScroll();

  // Astro navigation (clave del problema)
  document.addEventListener('astro:page-load', initHeaderScroll);
</script>