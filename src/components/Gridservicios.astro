            icon="../../public/video.svg"
            url="/servicios/desarrolloaplicaciones/"
            imagen="https://i.pinimg.com/webp/736x/92/f8/84/92f8842de3afbdbb2bf40aec32b7a176.webp"
            >
        </div>


    

    </div>


    <div class="w-10/12 h-auto flex lg:flex-row flex-col justify-center items-center  gap-6"></div>


    
    


</div>



