             icon="../../public/video.svg"
            url="/servicios/dossiersestrategicos/"
            imagen="https://i.pinimg.com/webp/736x/9d/30/63/9d3063e757db0d36f0e4b7b794d49874.webp"
            >
        </div>

        
        <div class="lg:w-4/12  h-auto">
            <Boxservicios titulo="desarrollo web"
            descripcion="Desarrollamos sitios web modernos, rápidos y a la medida de las necesidades de tu negocio."
