        </div>


    

    </div>

    
<br> 


    <div class="w-10/12 h-auto flex lg:flex-row flex-col justify-center items-center  gap-6"></div>


    
    


</div>



<div class="w-full h-auto flex flex-col justify-center items-center">


    <div class="w-10/12 h-auto flex lg:flex-row flex-col justify-center items-center gap-6">
    
    

        <div class="lg:w-4/12  h-auto">
            
            <Boxservicios titulo="dossiers estratégicos"
