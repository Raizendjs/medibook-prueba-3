---
const quickActions = [
  "Diseño Web",
  "SEO",
  "Marketing Digital",
  "Solicitar Cotización"
];
---

<div id="chat-widget">

  <button id="chat-toggle">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
      <path d="M20 12C20 16.4 16.4 20 12 20C10.5 20 9 19.6 7.8 18.9L4 20L5.1 16.2C4.4 15 4 13.5 4 12C4 7.6 7.6 4 12 4C16.4 4 20 7.6 20 12Z" stroke="currentColor" stroke-width="2"/>
    </svg>
  </button>

  <div class="chat-container">

    <div class="chat-header">
      <div class="avatar">
        AI
      </div>

      <div>
        <h3>Asistente IA</h3>
        <span>● En línea</span>
      </div>
    </div>

    <div class="chat-body" id="chat-body">

      <div class="message bot">
        👋 Hola, soy el asistente virtual.

        Puedo ayudarte con:

        ✅ Diseño Web

        ✅ SEO

        ✅ Marketing Digital

        ✅ Cotizaciones
      </div>

    </div>

    <div class="quick-actions">

      {quickActions.map(item => (
        <button class="quick-btn">
          {item}
        </button>
      ))}

    </div>

    <form class="chat-form" id="chat-form">
      <input
        id="chat-input"
        type="text"
        placeholder="Escribe tu consulta..."
      />

      <button type="submit">
        →
      </button>
    </form>

  </div>

</div>

<style>

#chat-widget{
position:fixed;
bottom:30px;
right:30px;
z-index:9999;
font-family:Inter,sans-serif;
}

#chat-toggle{
width:70px;
height:70px;
border:none;
cursor:pointer;
border-radius:50%;
background:linear-gradient(135deg,#2563eb,#7c3aed);
color:white;
box-shadow:0 15px 40px rgba(0,0,0,.25);
transition:.3s;
}

#chat-toggle:hover{
transform:translateY(-5px);
}

.chat-container{
position:absolute;
bottom:90px;
right:0;
width:380px;
height:620px;
background:white;
border-radius:25px;
overflow:hidden;
display:none;
flex-direction:column;
box-shadow:0 20px 60px rgba(0,0,0,.2);
}

.chat-container.active{
display:flex;
animation:show .3s ease;
}

@keyframes show{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:none;
}
}

.chat-header{
display:flex;
align-items:center;
gap:15px;
padding:20px;
background:linear-gradient(135deg,#2563eb,#7c3aed);
color:white;
}

.avatar{
width:50px;
height:50px;
display:flex;
align-items:center;
justify-content:center;
border-radius:50%;
background:rgba(255,255,255,.2);
font-weight:700;
}

.chat-header h3{
margin:0;
}

.chat-header span{
font-size:.8rem;
opacity:.9;
}

.chat-body{
flex:1;
overflow:auto;
padding:20px;
background:#f7f8fc;
}

.message{
max-width:85%;
padding:14px 18px;
border-radius:20px;
margin-bottom:15px;
line-height:1.5;
}

.bot{
background:white;
box-shadow:0 5px 20px rgba(0,0,0,.05);
}

.user{
background:#2563eb;
color:white;
margin-left:auto;
}

.quick-actions{
display:flex;
gap:8px;
padding:15px;
overflow:auto;
}

.quick-btn{
border:none;
padding:10px 15px;
border-radius:999px;
background:#eef2ff;
cursor:pointer;
white-space:nowrap;
}

.chat-form{
display:flex;
padding:15px;
border-top:1px solid #eee;
}

.chat-form input{
flex:1;
padding:14px;
border:none;
outline:none;
background:#f4f4f4;
border-radius:12px;
}

.chat-form button{
width:55px;
height:55px;
margin-left:10px;
border:none;
border-radius:12px;
cursor:pointer;
background:linear-gradient(135deg,#2563eb,#7c3aed);
color:white;
font-size:22px;
}

@media(max-width:768px){

.chat-container{
width:calc(100vw - 20px);
height:75vh;
right:-10px;
}

#chat-toggle{
width:60px;
height:60px;
}

}

</style>

<script>

const toggle = document.getElementById("chat-toggle");
const container = document.querySelector(".chat-container");
const form = document.getElementById("chat-form");
const input = document.getElementById("chat-input");
const body = document.getElementById("chat-body");

toggle.addEventListener("click", () => {
 container.classList.toggle("active");
});

function addMessage(text,type){

 const div = document.createElement("div");

 div.className = `message ${type}`;

 div.textContent = text;

 body.appendChild(div);

 body.scrollTop = body.scrollHeight;
}

document.querySelectorAll(".quick-btn").forEach(btn=>{

 btn.addEventListener("click",()=>{

  input.value = btn.innerText;

 });

});

form.addEventListener("submit",(e)=>{

 e.preventDefault();

 const text = input.value.trim();

 if(!text) return;

 addMessage(text,"user");

 input.value="";

 setTimeout(()=>{

   addMessage(
   "Gracias por tu consulta. Un agente IA procesará tu solicitud y te ayudará a encontrar el mejor servicio.",
   "bot"
   );

 },1000);

});

</script>