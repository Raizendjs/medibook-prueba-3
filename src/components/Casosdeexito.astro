---
const { caso1,caso2,caso3,caso4,text1,text2,text3,text4,img1,img2,img3,img4 } = Astro.props;

const items = [
  { title: caso1, text: text1, img: img1 },
  { title: caso2, text: text2, img: img2 },
  { title: caso3, text: text3, img: img3 },
  { title: caso4, text: text4, img: img4 },
];
---

<!-- ============================================================ -->
<!-- SECCIÓN 6: CASOS DE ÉXITO                                    -->
<!-- ============================================================ -->
<section class="px-4 sm:px-6 md:px-10 py-12 md:py-20 bg-dark border-t border-white/10">

  <!-- Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-8 md:mb-10">
    <div>
      <p class="text-red-500 text-xs font-bold tracking-widest uppercase mb-3">04 ——</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black uppercase dark:text-white leading-tight">
        CASOS DE <span class="text-red-500">ÉXITO</span>
      </h2>
    </div>
    <a href="#" class="self-start sm:self-auto inline-flex border dark:border-white/20 dark:text-white/60 text-[11px] font-bold tracking-widest uppercase px-5 py-3 hover:border-white hover:text-white transition">
      VER TODOS →
    </a>
  </div>

  <!-- Grid de casos -->
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-px bg-cardBorder shadow-2xl border border-gray-300 border-cardBorder">

    {items.map((item, i) => (
      <div
        class:list={[
          "p-5 md:p-6 flex flex-col justify-between gap-4 md:gap-6 min-h-[200px] md:min-h-[160px] group hover:bg-white/5 transition cursor-pointer",
          i % 2 === 0 ? "bg-gray-100 dark:bg-gray-900" : "bg-card"
        ]}
        data-gallery-item
        data-index={i}
        role="button"
        tabindex="0"
        aria-label={`Ver ${item.title}`}
      >
        <div>
          <p class="dark:text-white font-black text-base uppercase leading-tight">{item.title}</p>
          <p class="dark:text-white/30 text-[11px] mt-2 uppercase tracking-widest">{item.text}</p>
        </div>
        <span class="text-red-500 text-xs">↗</span>
        <div class="w-full h-48 sm:h-56 md:h-70 overflow-hidden">
          <img
            src={item.img}
            alt={item.title}
            class="w-full h-full object-cover transition duration-300 group-hover:scale-105"
          />
        </div>
      </div>
    ))}

  </div>

  <!-- Slider dots -->
  <div class="flex items-center gap-2 mt-6">
    <span class="w-6 h-1 bg-brand"></span>
    <span class="w-2 h-1 bg-white/20"></span>
    <span class="w-2 h-1 bg-white/20"></span>
  </div>

</section>

<!-- ============================================================ -->
<!-- LIGHTBOX                                                      -->
<!-- ============================================================ -->
<div
  id="gallery-lightbox"
  class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/90 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Visor de imagen"
>
  <div class="relative flex max-h-[90vh] w-full max-w-4xl flex-col items-center gap-4">

    <!-- Botón cerrar -->
    <button
      id="lb-close"
      class="absolute -top-10 right-0 text-white/60 hover:text-red-500 text-2xl leading-none transition"
      aria-label="Cerrar"
    >✕</button>

    <!-- Imagen -->
    <img
      id="lb-img"
      src=""
      alt=""
      class="max-h-[68vh] max-w-full rounded object-contain"
    />

    <!-- Info -->
    <div class="text-center">
      <p id="lb-title" class="font-black text-white uppercase text-sm"></p>
      <p id="lb-text" class="mt-1 text-[11px] uppercase tracking-widest text-white/40"></p>
    </div>

    <!-- Navegación -->
    <div class="flex items-center gap-3">
      <button
        id="lb-prev"
        class="flex h-10 w-10 items-center justify-center border border-white/30 text-white hover:border-white hover:bg-white/10 transition"
        aria-label="Anterior"
      >←</button>
      <span id="lb-counter" class="min-w-[3rem] text-center text-xs text-white/50"></span>
      <button
        id="lb-next"
        class="flex h-10 w-10 items-center justify-center border border-white/30 text-white hover:border-white hover:bg-white/10 transition"
        aria-label="Siguiente"
      >→</button>
    </div>

  </div>
</div>

<script>
  // Datos de la galería (sincronizados con los props de Astro)
  const cards = Array.from(document.querySelectorAll('[data-gallery-item]'));

  const items = cards.map(card => {
    const img  = card.querySelector('img') as HTMLImageElement;
    const title = card.querySelector('p:first-child')?.textContent ?? '';
    const text  = card.querySelector('p:last-child')?.textContent ?? '';
    return { img: img?.src ?? '', title, text };
  });

  let current = 0;

  const lb       = document.getElementById('gallery-lightbox')!;
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
  const lbTitle  = document.getElementById('lb-title')!;
  const lbText   = document.getElementById('lb-text')!;
  const lbCounter = document.getElementById('lb-counter')!;

  function openLightbox(index: number) {
    current = index;
    updateLightbox();
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function updateLightbox() {
    const item = items[current];
    lbImg.src = item.img;
    lbImg.alt = item.title;
    lbTitle.textContent = item.title;
    lbText.textContent  = item.text;
    lbCounter.textContent = `${current + 1} / ${items.length}`;
  }

  // Abrir al hacer clic en una card
  cards.forEach(card => {
    const handler = () => openLightbox(Number(card.dataset.index));
    card.addEventListener('click', handler);
    card.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') handler();
    });
  });

  // Navegación
  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')!.addEventListener('click', () => {
    current = (current - 1 + items.length) % items.length;
    updateLightbox();
  });
  document.getElementById('lb-next')!.addEventListener('click', () => {
    current = (current + 1) % items.length;
    updateLightbox();
  });

  // Clic fuera → cerrar
  lb.addEventListener('click', (e) => {
    if (e.target === lb) closeLightbox();
  });

  // Teclado
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('flex')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowLeft')  { current = (current - 1 + items.length) % items.length; updateLightbox(); }
    if (e.key === 'ArrowRight') { current = (current + 1) % items.length; updateLightbox(); }
  });
</script>