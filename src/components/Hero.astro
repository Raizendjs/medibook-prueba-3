---
import Button from './Button.astro';
import Badge from './Badge.astro';
import { resolvePath } from '../utils/navigation';
import Sliderhome from './Sliderhome.astro';
import Title from './Title.astro';
import VideoHero from './VideoHero.astro';
---

<section class="hero-section relative min-h-screen overflow-hidden">

  <!-- ===== ANIMATED BACKGROUND ===== -->
  <div class="absolute inset-0 -z-10 bg-white dark:bg-[#09090b]">
    <!-- Dot grid -->
    <div class="absolute inset-0
      bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgwLDAsMCwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')]
      dark:bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgyNTUsMjU1LDI1NSwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')]
      [mask-image:linear-gradient(to_bottom,white,transparent)]">
    </div>
    <!-- Orb 1 — top right, pulses -->
    <div class="orb-1 absolute top-0 right-0 -translate-y-12 translate-x-1/3
      w-[600px] h-[500px] md:w-[900px] md:h-[700px]
      bg-primary-400/25 dark:bg-primary-900/35
      rounded-full blur-[120px] opacity-90
      mix-blend-multiply dark:mix-blend-screen">
    </div>
    <!-- Orb 2 — bottom left, drifts -->
    <div class="orb-2 absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3
      w-[500px] h-[400px] md:w-[700px] md:h-[600px]
      bg-accent-400/20 dark:bg-accent-900/30
      rounded-full blur-[100px] opacity-80
      mix-blend-multiply dark:mix-blend-screen">
    </div>
    <!-- Orb 3 — mid, extra depth -->
    <div class="orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
      w-[300px] h-[300px] md:w-[500px] md:h-[500px]
      bg-blue-300/10 dark:bg-blue-700/15
      rounded-full blur-[80px] opacity-60
      mix-blend-screen">
    </div>
  </div>

  <!-- ===== GRID LAYOUT ===== -->
  <div class="hero-grid grid grid-cols-1 lg:grid-cols-[42%_58%] gap-0 min-h-screen">

    <!-- ===== LEFT COLUMN ===== -->
    <div class="hero-left flex items-center justify-center lg:justify-start
      px-6 sm:px-10 lg:pl-14 xl:pl-20
      pt-24 pb-10 lg:py-0">

      <div class="w-full max-w-xl">

        <!-- Eyebrow badge -->
        <div class="hero-eyebrow will-animate inline-flex items-center gap-2
          px-4 py-1.5 mb-6 md:mb-8
          rounded-full border border-blue-300/60 dark:border-blue-700/50
          bg-blue-50/80 dark:bg-blue-950/50 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-blue-500 dark:bg-blue-400 animate-pulse flex-shrink-0"></span>
          <span class="text-xs sm:text-sm font-semibold uppercase tracking-widest
            text-blue-700 dark:text-blue-300 whitespace-nowrap">
            Comunicación estratégica
          </span>
        </div>

        <!-- Main title -->
        <div class="hero-title will-animate mb-5 md:mb-7">
          <Title />
        </div>

        <!-- Subheading -->
        <p class="hero-subtitle will-animate
          text-lg sm:text-xl md:text-2xl font-bold uppercase tracking-wide
          text-slate-700 dark:text-slate-200
          leading-snug mb-8 md:mb-10 max-w-lg">
          Contenido editorial<br class="hidden sm:block" />
          y producción multiplataforma
        </p>

        <!-- CTA group -->
        <div class="hero-cta will-animate flex flex-col sm:flex-row gap-3 sm:gap-4">
          <Button
            href={resolvePath('/pricing/')}
            variant="primary"
            size="lg"
            class="w-full sm:w-auto text-base sm:text-lg font-extrabold uppercase tracking-wider
              shadow-lg shadow-blue-500/20 hover:shadow-xl hover:shadow-blue-500/30
              transition-all duration-300"
          >
            Cómo trabajamos →
          </Button>

          <Button
            href="#features"
            variant="outline"
            size="lg"
            class="w-full sm:w-auto text-base sm:text-lg font-extrabold uppercase tracking-wider
              hover:scale-[1.02] transition-all duration-300"
          >
            Agendar reunión
          </Button>
        </div>

        <!-- Scroll hint -->
        <div class="hero-scroll-hint will-animate flex items-center gap-3 mt-10 md:mt-12 text-slate-400 dark:text-slate-600">
          <div class="scroll-mouse w-6 h-9 rounded-full border-2 border-current flex items-start justify-center pt-1.5">
            <div class="scroll-wheel w-1 h-2 rounded-full bg-current"></div>
          </div>
          <span class="text-xs sm:text-sm font-semibold uppercase tracking-widest">Explorar</span>
        </div>

      </div>
    </div>

    <!-- ===== RIGHT COLUMN ===== -->
    <div class="hero-right flex items-center justify-center
      px-0 sm:px-0 lg:px-0 xl:pr-0
      pb-16 lg:pb-0 pt-0 lg:pt-0
      relative">

      <!-- Decorative floating rings -->
      <div class="ring-1-deco absolute top-1/4 right-8 w-16 h-16 md:w-24 md:h-24
        rounded-full border-2 border-blue-300/30 dark:border-blue-700/30 pointer-events-none">
      </div>
      <div class="ring-2-deco absolute bottom-1/4 left-8 w-10 h-10 md:w-16 md:h-16
        rounded-full border-2 border-primary-300/30 dark:border-primary-700/30 pointer-events-none">
      </div>

      <!-- Video wrapper with reveal frame -->
      <div class="hero-video-wrapper will-animate relative w-full max-w-full">
        <!-- Glow ring around video -->
        <div class="absolute -inset-1 rounded-2xl
          bg-gradient-to-br from-blue-400/30 via-primary-400/20 to-accent-400/30
          dark:from-blue-600/20 dark:via-primary-600/15 dark:to-accent-600/20
          blur-lg pointer-events-none">
        </div>
        <!-- Video component -->
        <div class="relative  overflow-hidden
          ring-1 ring-white/20 dark:ring-white/10
          shadow-2xl shadow-blue-500/10 dark:shadow-blue-900/30">
          <VideoHero />
        </div>
      </div>

    </div>

  </div>
</section>


<!-- ===== GSAP ANIMATIONS ===== -->
<script>
  import gsap from "gsap";

  function revealAll() {
    document.querySelectorAll(".will-animate").forEach((el) => {
      (el as HTMLElement).style.opacity = "1";
      (el as HTMLElement).style.transform = "none";
    });
  }

  function initHeroAnimations() {
    const elements = document.querySelectorAll(".will-animate");
    if (!elements.length) return;

    // Safety net: if GSAP hasn't finished in 3s, reveal everything
    const safetyTimer = setTimeout(revealAll, 3000);

    try {
      const mm = gsap.matchMedia();

      // ── Orb ambient floats ──
      gsap.to(".orb-1", { y: -40, x: 20, duration: 8, ease: "sine.inOut", yoyo: true, repeat: -1 });
      gsap.to(".orb-2", { y: 30, x: -25, duration: 10, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1 });
      gsap.to(".orb-3", { scale: 1.15, opacity: 0.8, duration: 6, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 0.5 });

      // ── Decorative rings spin ──
      gsap.to(".ring-1-deco", { rotation: 360, duration: 18, ease: "none", repeat: -1 });
      gsap.to(".ring-2-deco", { rotation: -360, duration: 22, ease: "none", repeat: -1 });

      // ── Scroll wheel bounce ──
      gsap.to(".scroll-wheel", { y: 10, opacity: 0, duration: 1.2, ease: "power2.in", yoyo: true, repeat: -1 });

      // ── Master entrance timeline — animates FROM invisible TO visible ──
      // Elements start invisible via CSS (.will-animate), GSAP reveals them
      gsap.set(".hero-eyebrow",      { opacity: 0, y: -20 });
      gsap.set(".hero-title",        { opacity: 0, y: 50, scale: 0.97 });
      gsap.set(".hero-subtitle",     { opacity: 0, y: 35 });
      gsap.set(".hero-cta",          { opacity: 0, y: 30 });
      gsap.set(".hero-scroll-hint",  { opacity: 0, y: 20 });
      gsap.set(".hero-video-wrapper",{ opacity: 0, x: 60, scale: 0.96 });
      gsap.set([".ring-1-deco", ".ring-2-deco"], { opacity: 0, scale: 0 });

      const tl = gsap.timeline({
        defaults: { ease: "power3.out" },
        onComplete: () => clearTimeout(safetyTimer),
      });

      tl
        .to(".hero-eyebrow",      { opacity: 1, y: 0, duration: 0.7 }, 0.15)
        .to(".hero-title",        { opacity: 1, y: 0, scale: 1, duration: 0.9 }, 0.35)
        .to(".hero-subtitle",     { opacity: 1, y: 0, duration: 0.8 }, 0.6)
        .to(".hero-cta",          { opacity: 1, y: 0, duration: 0.7 }, 0.8)
        .to(".hero-scroll-hint",  { opacity: 1, y: 0, duration: 0.6 }, 1.0)
        .to(".hero-video-wrapper",{ opacity: 1, x: 0, scale: 1, duration: 1.1, ease: "power4.out" }, 0.5)
        .to([".ring-1-deco", ".ring-2-deco"], {
            opacity: 1, scale: 1, duration: 0.8, stagger: 0.2, ease: "back.out(2)",
          }, 0.8);

      // ── Hover micro-interactions (desktop only) ──
      mm.add("(min-width: 1024px)", () => {
        document.querySelectorAll(".hero-cta a, .hero-cta button").forEach((el) => {
          el.addEventListener("mouseenter", () => gsap.to(el, { scale: 1.04, duration: 0.25, ease: "power2.out" }));
          el.addEventListener("mouseleave", () => gsap.to(el, { scale: 1, duration: 0.2, ease: "power2.in" }));
        });
      });

    } catch (err) {
      // GSAP threw — reveal everything immediately
      clearTimeout(safetyTimer);
      revealAll();
    }
  }

  // Run on first load and on Astro view transitions
  document.addEventListener("astro:page-load", initHeroAnimations);
</script>


<style>
  /* ── Fallback: si JS está desactivado, mostrar todo ── */
  .will-animate {
    opacity: 1;
  }

  /* ── Reduced-motion: nunca ocultar, sin animaciones ── */
  @media (prefers-reduced-motion: reduce) {
    .will-animate {
      opacity: 1 !important;
      transform: none !important;
    }
    .orb-1, .orb-2, .orb-3,
    .ring-1-deco, .ring-2-deco,
    .scroll-wheel {
      animation: none !important;
    }
  }

  /* ── Crisp text rendering ── */
  .hero-title,
  .hero-subtitle,
  .hero-eyebrow {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
</style>