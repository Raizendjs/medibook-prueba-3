---

const {
  videoSrc = "https://assets.codepen.io/11990995/VID-20260122-WA0003.mp4",
  backgroundImage = "foreverfondo.webp",
  titleTop = "Forever",
  titleBottom = "studio",
  subtitle = "Diseñamos historias que generan posicionamiento"
} = Astro.props;

---

<main class="film">
  <section class="scene scene-wallpaper active" data-scene="wallpaper">
    <div
      class="wallpaper"
      style={`background-image:
      linear-gradient(to bottom, rgba(2,8,20,.2), rgba(0,0,0,.8)),
      url('${backgroundImage}')`}
    ></div>

    <div class="title-block">
      <p class="eyebrow w-25">{subtitle}</p>

      <h1>
        <span class="title-top">
          {titleTop}<span class="macron">¯</span>
        </span>

        <span class="title-bottom">{titleBottom}</span>
      </h1>
    </div>

    <button class="start-btn">Start Transmission</button>
  </section>

  <section class="scene scene-black" data-scene="caption">
    <p class="caption-text">
      someone said they disco at night.
    </p>
  </section>

  <section class="scene scene-video" data-scene="video">
    <div class="video-frame">
      <video class="penguin-video" playsinline controls>
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </section>

  <div class="fade-layer"></div>

  <section class="scene scene-black final" data-scene="final">
    <p class="final-text">
      yes.<br />
      turn the lights off.
    </p>

    <button class="replay-btn">
      Replay Transmission
    </button>
  </section>
</main>

<script>
  document.querySelectorAll(".film").forEach((film) => {
    const startBtn = film.querySelector(".start-btn");
    const replayBtn = film.querySelector(".replay-btn");

    const wallpaperScene = film.querySelector('[data-scene="wallpaper"]');
    const captionScene = film.querySelector('[data-scene="caption"]');
    const videoScene = film.querySelector('[data-scene="video"]');
    const finalScene = film.querySelector('[data-scene="final"]');

    const video = film.querySelector(".penguin-video");
    const fadeLayer = film.querySelector(".fade-layer");

    // if a required UI piece is missing bail out for this film instance
    if (!fadeLayer) return;

    function hideAllScenes() {
      film.querySelectorAll(".scene").forEach((scene) => {
        scene.classList.remove("active");
      });
    }

    /**
     * @param {Element | null} nextScene
     * @param {number} [delay]
     */
    function transitionTo(nextScene, delay = 1200) {
      fadeLayer.classList.add("show");

      setTimeout(() => {
        hideAllScenes();

        if (nextScene) {
          nextScene.classList.add("active");
        }

        setTimeout(() => {
          fadeLayer.classList.remove("show");
        }, 100);
      }, delay);
    }

    startBtn?.addEventListener("click", () => {
      transitionTo(captionScene);

      if (video instanceof HTMLVideoElement) {
        video.volume = 0.35;
      }

      setTimeout(() => {
        transitionTo(videoScene);

        setTimeout(() => {
          if (video instanceof HTMLVideoElement) {
            video.currentTime = 0;
            // play() returns a promise in some browsers; we don't need to await here
            video.play();
          }
        }, 1400);
      }, 4200);
    });

    if (video instanceof HTMLVideoElement) {
      video.addEventListener("ended", () => {
        transitionTo(finalScene);
      });
    }

    replayBtn?.addEventListener("click", () => {
      if (video instanceof HTMLVideoElement) {
        video.pause();
        video.currentTime = 0;
      }

      transitionTo(wallpaperScene);
    });
  });
</script>

<style>
@import url("https://fonts.googleapis.com/css2?family=Anton&family=Montserrat:wght@300;500;700&display=swap");

* {
  box-sizing: border-box;
}

.film {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
  overflow: hidden;
  font-family: "Montserrat", sans-serif;
}

.scene {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
}

.scene.active {
  opacity: 1;
  pointer-events: auto;
}

.wallpaper {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transform: scale(1.08);
  animation: slowDrift 12s ease-in-out infinite alternate;
}

.title-block {
  position: absolute;
  left: 7vw;
  bottom: 16vh;
  z-index: 2;
  color: #fff;
}

.eyebrow {
  font-size: clamp(.7rem,1.5vw,.9rem);
  letter-spacing: .35rem;
  text-transform: uppercase;
  color: rgba(255,255,255,.65);
  margin-bottom: 1rem;
}

h1 {
  display: flex;
  flex-direction: column;
  font-family: Anton,sans-serif;
  font-size: clamp(4rem,12vw,10rem);
  line-height: .92;
  text-transform: uppercase;
}

.macron {
  position: relative;
  left: -.58em;
  top: -.6em;
  font-size: .68em;
}

.start-btn,
.replay-btn {
  cursor: pointer;
  color: #fff;
  border: 1px solid rgba(255,255,255,.3);
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(8px);
}

.start-btn {
  position: absolute;
  right: 7vw;
  bottom: 10vh;
  padding: 1rem 1.5rem;
}

.scene-black {
  display: grid;
  place-items: center;
  background: #000;
  color: white;
  text-align: center;
  padding: 2rem;
}

.caption-text,
.final-text {
  font-size: clamp(1.8rem,5vw,4.5rem);
}

.scene-video {
  display: grid;
  place-items: center;
  background: #000;
  padding: 2rem;
}

.video-frame {
  width: min(900px,92vw);
}

video {
  width: 100%;
  display: block;
}

.fade-layer {
  position: absolute;
  inset: 0;
  background: #000;
  opacity: 0;
  pointer-events: none;
  transition: 1.2s ease;
  z-index: 15;
}

.fade-layer.show {
  opacity: 1;
}

.replay-btn {
  margin-top: 2rem;
  padding: 1rem 1.5rem;
}

@keyframes slowDrift {
  from {
    transform: scale(1.08) translateX(-1%);
  }

  to {
    transform: scale(1.13) translateX(1.5%);
  }
}

@media (max-width:768px) {
  .title-block {
    left: 1.5rem;
    right: 1.5rem;
  }

  .start-btn {
    left: 1.5rem;
    right: 1.5rem;
    width: calc(100% - 3rem);
  }
}
</style>