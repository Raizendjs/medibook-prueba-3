---
<h1 class="hero-title">
  <span class="line">Creamos historias</span>
  <span class="line">que <span class="text-red-700"> posicionan marcas</span>
  <span class="line">donde realmente importa.</span>
</h1>

<script>
  import gsap from "gsap";

  document.addEventListener("astro:page-load", () => {
    const lines = gsap.utils.toArray(".line");

    gsap.set(lines, {
      y: 100,
      opacity: 0,
      filter: "blur(10px)",
      rotateX: -45,
      transformOrigin: "50% 100%"
    });

    gsap.timeline({
      defaults: { ease: "power4.out" }
    })
    .to(lines, {
      y: 0,
      opacity: 1,
      rotateX: 0,
      filter: "blur(0px)",
      duration: 2.4
    })
    .to(lines, {
      y: -10,
      duration: 0.25,
      ease: "power2.out"
    })
    .to(lines, {
      y: 0,
      duration: 0.35,
      ease: "power2.out"
    });
  });
</script>

<style>
.hero-title{
  margin:0;
  padding:0;
  width:100%;
  max-width:1200px;
}

.line{
  display:block;
  text-align: left;

  font-family:'Inter',sans-serif;
  font-size:clamp(3rem,4vw,3.5rem);
  font-weight:900;
  text-transform: uppercase;
  font-display: auto;

  line-height:1.00;
  letter-spacing:-0.06em;

  /* Permite saltos de línea */
  white-space:normal;
  text-wrap:balance;

  will-change:transform, opacity;
}

@media (max-width:768px){
  .line{
    font-size:clamp(2rem,10vw,4rem);
    line-height:1;
  }
}
</style>