---
// BookingSlider.astro
// Slider de alojamientos — AHORA conectado directo a Supabase.
// Ya no usa datos falsos: trae tus listings reales (tabla `listings` + `listing_images`)
// y cada tarjeta enlaza a /listings/{id}/, igual que el resto de tu app.

import { createSupabaseServerClient } from "../lib/supabase/server";

interface Props {
  limit?: number;
  label?: string;
  heading?: string;
}

const {
  limit = 12,
  label = "Alojamientos disponibles",
  heading = "Encuentra tu próxima estadía",
} = Astro.props;

const supabase = createSupabaseServerClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const { data: listingsRaw, error } = await supabase
  .from("listings")
  .select(
    "id, title, city, country, price, currency, created_at, listing_images(url, order_index)"
  )
  .eq("status", "active")
  .order("created_at", { ascending: false })
  .limit(limit);

function getCoverUrl(listing: any) {
  if (!listing.listing_images || listing.listing_images.length === 0) return null;
  const sorted = [...listing.listing_images].sort(
    (a: any, b: any) => a.order_index - b.order_index
  );
  return sorted[0].url;
}

// Como no tienes (todavía) un sistema de reseñas, no se puede mostrar
// rating/reviews reales — se quitó esa parte en vez de inventar números.
// "Nuevo" sí es un dato real: listings publicados en los últimos 14 días.
const FOURTEEN_DAYS_MS = 1000 * 60 * 60 * 24 * 14;

const stays = (listingsRaw ?? []).map((l: any) => {
  const createdAt = new Date(l.created_at).getTime();
  const isNew = Date.now() - createdAt < FOURTEEN_DAYS_MS;

  return {
    id: l.id,
    title: l.title as string,
    location: l.city ? `${l.city}, ${l.country}` : (l.country as string),
    price: l.price as number,
    currency: l.currency as string,
    badge: isNew ? "Nuevo" : null,
    image: getCoverUrl(l),
    link: `/listings/${l.id}/`,
  };
});
---

<section class="stays-container relative w-full py-12 bg-[#FAFAF8] dark:bg-[#0B1120] transition-colors duration-500">
  <div class="stays-header flex items-end justify-between px-5 pb-6 md:px-16">
    <div>
      <span class="label text-sm font-semibold uppercase tracking-[0.08em] text-[#C6482F] dark:text-[#F2A38A]">
        {label}
      </span>
      <h2 class="heading mt-2 font-bold leading-[1.1] text-slate-900 dark:text-white text-[clamp(1.5rem,3.2vw,2.5rem)]">
        {heading}
      </h2>
    </div>

    {stays.length > 0 && (
      <div class="hidden md:flex gap-2">
        <button
          class="nav-btn prev flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition-all duration-200 hover:border-slate-400 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
          aria-label="Anterior"
        >
          &#8592;
        </button>
        <button
          class="nav-btn next flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition-all duration-200 hover:border-slate-400 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
          aria-label="Siguiente"
        >
          &#8594;
        </button>
      </div>
    )}
  </div>

  {error && (
    <p class="px-5 md:px-16 text-sm text-[#FF385C]">
      No se pudieron cargar los alojamientos. Intenta de nuevo más tarde.
    </p>
  )}

  {!error && stays.length === 0 && (
    <div class="px-5 md:px-16 py-10 text-center">
      <p class="text-slate-900 dark:text-white font-semibold">
        Aún no hay alojamientos publicados
      </p>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">
        Vuelve pronto, estamos agregando nuevas propiedades.
      </p>
    </div>
  )}

  {!error && stays.length > 0 && (
    <div
      class="stays-slider flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory px-5 pb-4 md:px-16"
      id="staysSlider"
    >
      {stays.map((stay, index) => (
        <a
          href={stay.link}
          class="stay-card group shrink-0 snap-start w-[240px] md:w-[268px] cursor-pointer"
          data-index={index}
        >
          <div class="stay-media relative overflow-hidden rounded-2xl aspect-[4/3] bg-neutral-100 dark:bg-slate-800">
            {stay.image ? (
              <img
                src={stay.image}
                alt={stay.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.06]"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-slate-400 text-sm">
                Sin foto
              </div>
            )}

            {stay.badge && (
              <span class="absolute left-3 top-3 rounded-full bg-white/95 px-2.5 py-1 text-[0.68rem] font-semibold text-slate-900 shadow-sm dark:bg-slate-900/90 dark:text-white">
                {stay.badge}
              </span>
            )}

            <button
              class="fav-btn absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-full bg-black/10 backdrop-blur-sm transition-transform duration-150 hover:scale-110"
              aria-label="Guardar en favoritos"
              data-fav="false"
            >
              <svg class="heart-icon h-[18px] w-[18px] stroke-white stroke-[2] fill-transparent transition-all" viewBox="0 0 24 24">
                <path d="M12 21s-7.5-4.6-10-9.1C.4 8.6 2 5 5.6 5c2 0 3.3 1 4.4 2.4C11.1 6 12.4 5 14.4 5 18 5 19.6 8.6 22 11.9 19.5 16.4 12 21 12 21z"/>
              </svg>
            </button>
          </div>

          <div class="stay-info mt-2.5">
            <h3 class="truncate text-[0.92rem] font-semibold text-slate-900 dark:text-slate-50">
              {stay.title}
            </h3>

            <p class="mt-0.5 truncate text-[0.85rem] text-slate-500 dark:text-slate-400">
              {stay.location}
            </p>

            <p class="mt-1.5 text-[0.92rem] text-slate-900 dark:text-slate-50">
              <span class="font-semibold">{stay.currency} {stay.price}</span>{" "}
              <span class="text-slate-500 dark:text-slate-400">/ noche</span>
            </p>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<script>
  function initStaysSlider() {
    const slider = document.querySelector<HTMLElement>("#staysSlider");
    const nextBtn = document.querySelector<HTMLButtonElement>(".stays-container .next");
    const prevBtn = document.querySelector<HTMLButtonElement>(".stays-container .prev");
    const favButtons = document.querySelectorAll<HTMLButtonElement>(".fav-btn");

    if (!slider) return;

    nextBtn?.addEventListener("click", () => {
      slider.scrollBy({ left: 320, behavior: "smooth" });
    });

    prevBtn?.addEventListener("click", () => {
      slider.scrollBy({ left: -320, behavior: "smooth" });
    });

    favButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isFav = btn.dataset.fav === "true";
        btn.dataset.fav = isFav ? "false" : "true";
        const icon = btn.querySelector<SVGElement>(".heart-icon");
        if (icon) {
          icon.classList.toggle("fill-[#E85D4E]", !isFav);
          icon.classList.toggle("stroke-[#E85D4E]", !isFav);
          icon.classList.toggle("stroke-white", isFav);
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initStaysSlider);
</script>

<script>
  // Animación de entrada al hacer scroll (GSAP + ScrollTrigger)
  // Requiere: npm install gsap
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initScrollAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    const section = document.querySelector<HTMLElement>(".stays-container");
    if (!section) return;

    ScrollTrigger.getAll().forEach((st) => {
      if (st.trigger && section.contains(st.trigger as Node)) st.kill();
    });

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) return;

    const tl = gsap.timeline({
      scrollTrigger: { trigger: section, start: "top 80%", once: true },
      defaults: { ease: "power3.out" },
    });

    tl.from(".stays-header .label", { opacity: 0, y: 14, duration: 0.5, clearProps: "all" })
      .from(".stays-header .heading", { opacity: 0, y: 20, duration: 0.6, clearProps: "all" }, "-=0.3")
      .from(
        ".stay-card",
        { opacity: 0, y: 34, duration: 0.6, stagger: 0.08, clearProps: "all" },
        "-=0.2"
      );
  }

  document.addEventListener("astro:page-load", initScrollAnimations);
</script>

<style>
  #staysSlider {
    scrollbar-width: none;
  }
  #staysSlider::-webkit-scrollbar {
    display: none;
  }
</style>