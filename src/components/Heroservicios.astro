---
const stats = [
  { value: "120+", label: "Proyectos" },
  { value: "250+", label: "Clientes" },
  { value: "98%", label: "Satisfacción" },
];
---

<section  class="relative overflow-hidden ">
  <!-- Fondo -->
  <div class="absolute inset-0 opacity-40">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,#d9d9d920_0%,transparent_70%)]"
    />
  </div>

  <div
    class="relative mx-auto max-w-10/12 px-6 py-26 lg:grid lg:grid-cols-2 lg:items-center lg:gap-10"
  >
    <!-- Texto -->
    <div class="max-w-11/12 ">
      <span
        class="mb-4 inline-block text-sm font-bold uppercase tracking-[3px] text-red-600"
      >
        Servicios
      </span>

      <h1
        class="text-4xl font-black uppercase leading-[0.95] text-zinc-900 dark:text-white md:text-6xl"
      >
        Estrategias, contenido y experiencias que marcan
        <span class="text-red-600"> oportunidades</span>
      </h1>

      <p class="mt-6 max-w-md text-zinc-600 dark:text-white">
        En Forever Studio transformamos ideas en soluciones creativas y
        digitales que conectan marcas con personas. Conoce todo lo que podemos
        hacer por tu negocio.
      </p>

      <a
        href="#"
        class="mt-8 inline-flex items-center gap-3 bg-red-600 px-7 py-4 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-red-700"
      >
        Hablemos de tu proyecto
        <span>→</span>
      </a>
    </div>

    <!-- Mockup -->
    <div class="relative mt-14 lg:mt-0">
      <!-- manchas -->
      <div
        class="absolute left-60 top-0 h-64 w-64 rounded-full bg-red-500/20 blur-3xl"
      />

      <div
        class="absolute right-0 top-14 h-64 w-64 rounded-full bg-blue-500/20 blur-3xl"
      />

      <!-- Laptop -->
      <img src="../../public/pclab.webp" alt="">
    </div>
  </div>
</section>