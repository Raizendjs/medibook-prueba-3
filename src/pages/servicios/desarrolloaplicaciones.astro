---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Desarrollo de Aplicaciones" description="Desarrollamos aplicaciones móviles y web a medida que resuelven problemas reales, escalan con tu negocio y ofrecen una experiencia de usuario excepcional.">

  <Headerservicios titulo="desarrollo de" span="aplicaciones" ruta="desarrollo de aplicaciones"
  imagen="https://i.pinimg.com/1200x/17/ec/db/17ecdb37c5620036215fac1c43209ada.jpg"
  descripcion="Desarrollamos aplicaciones móviles y web a medida que resuelven problemas reales, escalan con tu negocio y ofrecen una experiencia de usuario excepcional." />

  <Quehacemos descripcion="Creamos aplicaciones a medida con foco en usabilidad, rendimiento y escalabilidad. Desde la idea hasta el lanzamiento, acompañamos cada etapa del desarrollo para que el producto final supere tus expectativas."
  text1="Aplicaciones móviles iOS y Android"
  text2="Apps web progresivas (PWA)"
  text3="Diseño UI/UX centrado en el usuario"
  text4="Integraciones con APIs y servicios externos"
  text5="Arquitectura escalable y segura"
  text6="Soporte, mantenimiento y actualizaciones"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Soluciones de software a medida que automatizan procesos, mejoran la experiencia de tus usuarios y hacen crecer tu negocio."
  item1="01 — APPS MÓVILES"
  desc1="Aplicaciones nativas y multiplataforma para iOS y Android con rendimiento y diseño de primer nivel."
  item2="02 — APLICACIONES WEB"
  desc2="Plataformas y sistemas web robustos, escalables y adaptados a las necesidades de tu negocio."
  item3="03 — DISEÑO UI/UX"
  desc3="Interfaces intuitivas y atractivas diseñadas para maximizar la retención y satisfacción del usuario."
  item4="04 — INTEGRACIONES Y APIs"
  desc4="Conectamos tu aplicación con pasarelas de pago, CRMs, ERPs y cualquier servicio externo que necesites."
  item5="05 — AUTOMATIZACIÓN DE PROCESOS"
  desc5="Digitalizamos y automatizamos flujos de trabajo para reducir errores y aumentar la eficiencia operativa."
  item6="06 — MANTENIMIENTO Y SOPORTE"
  desc6="Actualizaciones, monitoreo, corrección de errores y soporte técnico continuo post-lanzamiento."
  />

  <Nuestrosprocesos
  text1="01 — DISCOVERY"
  desc1="Analizamos tu idea, necesidades, usuarios y requerimientos técnicos del proyecto."
  text2="02 — DISEÑO"
  desc2="Creamos wireframes, prototipos y el diseño UI/UX validado antes de escribir código."
  text3="03 — DESARROLLO"
  desc3="Construimos la aplicación por sprints con entregas parciales y revisiones constantes."
  text4="04 — QA Y PRUEBAS"
  desc4="Testeo funcional, de rendimiento y experiencia de usuario antes del lanzamiento."
  text5="05 — LANZAMIENTO"
  desc5="Publicamos la app y te acompañamos en el crecimiento con soporte continuo."
  />

  <Casosdeexito
  caso1="LogiTrack"
  text1="App de Gestión Logística y Rutas"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="MediCare Plus"
  text2="Plataforma de Citas Médicas Online"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="EduFlow"
  text3="App de Aprendizaje E-learning"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="MarketPlace Andino"
  text4="Plataforma de Comercio Electrónico"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+250%"
  text1="Más eficiencia operativa para nuestros clientes"

  dato2="+92%"
  text2="Satisfacción de usuarios en apps desarrolladas"

  dato3="100%"
  text3="Proyectos lanzados en tiempo y dentro del presupuesto"
  />

  <CtaFinal />

</BaseLayout>