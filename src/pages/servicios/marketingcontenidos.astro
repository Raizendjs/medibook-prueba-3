<BaseLayout title="Marketing de Contenidos" description="Creamos y distribuimos contenido estratégico que atrae, convierte y fideliza a tu audiencia ideal en cada etapa del funnel.">

  <Headerservicios titulo="marketing de" span="contenidos" ruta="marketing de contenidos"
  imagen="https://i.pinimg.com/webp/1200x/4d/1f/2c/4d1f2c6aae7f4590b8931e1b8ca01fd0.webp"
  descripcion="Creamos y distribuimos contenido estratégico que atrae, convierte y fideliza a tu audiencia ideal en cada etapa del funnel." />

