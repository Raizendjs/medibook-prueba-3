---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Desarrollo web" description="Latest updates, thoughts, and tutorials from the Zenix team.">
    
    <Headerservicios titulo="desarrollo" span="web" ruta="desarrolo web"
    imagen="https://i.pinimg.com/736x/4e/84/78/4e8478aaf66a577f5eba1f188f0af944.jpg"
    descripcion="Creamos sitios web rápidos, funcionales y optimizados para convertir visitantes en clientes y potenciar tu presencia digital." /> 
    
    <Quehacemos descripcion="Desarrollamos sitios web a medida que combinan diseño creativo, tecnología y estrategia. Nos enfocamos en la experiencia del usuario, la velocidad, el posicionamiento y la conversión."
    text1="Diseño UI/UX centrado en usuarios"
    text2="Desarrollo Frontend de rendimiento"
    text3="Backend robusto y seguro"
    text4="SEO técnico y posicionamiento"
    text5="Optimización de velocidad y rendimiento"
    text6="Mantenimiento y soporte continuo"
    src=https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
    />

  <Servicios descripcion="Soluciones integrales para que tu sitio web no solo se vea increíble, sino que también funcione perfectamente y genere resultados."
  item1="01 — DISEÑO WEB PERSONALIZADO"
  desc1="Interfaces únicas, modernas y alineadas a tu marca y objetivos."
  item2="02 — DESARROLLO WEB A MEDIDA"
  desc2="Sitios rápidos, funcionales y escalables con tecnologías actuales."
   item3="03 — TIENDAS ONLINE (E-COMMERCE)"
  desc3="Plataformas de venta optimizadas para una experiencia de compra impecable."
   item4="04 — SEO & POSICIONAMIENTO"
  desc4="Optimizamos tu sitio para que aparezcas en los primeros lugares de Google."
   item5="05 — VELOCIDAD & RENDIMIENTO"
  desc5="Mejoramos los tiempos de carga para una experiencia de usuario superior."
   item6="04 - MANTENIMIENTO & SOPORTE"
  desc6="Actualizaciones, backups y soporte técnico para que tu web siempre esté al 100%."
  />

  <Nuestrosprocesos 
  text1="01 — DESCUBRIMIENTO"
  desc1="Entendemos tu negocio, objetivos y audiencia." 
  text2="02 — DISEÑO"
  desc2="Creamos wireframes y diseños enfocados en experiencia y conversión." 
  text3="03 — DESARROLLO"
  desc3="Convertimos el diseño en un sitio web funcional, rápido y seguro.                                                                                                                                                                                                                                                                                  " 
  text4="04 — PRUEBAS"
  desc4="Verificamos rendimiento, compatibilidad y experiencia de usuario." 
  text5="05 — Seo"
  desc5="Publicamos tu sitio y te acompañamos en el crecimiento." 
  />

  <Casosdeexito 
  caso1="radioforever925.com"
  text1="Sitio Web blog de noticias"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="radioforeverdeportes.com"
  text2="Sitio Web blog de noticias"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"
  
  caso3="radioforever925.com"
  text3="Sitio Web blog de noticias"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"
  
  caso4="radioforever925.com"
  text4="Sitio Web blog de noticias"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />


  <Resultados
  dato1="+300%"
  text1="Más conversiones para nuestros clientes"
  
  
  dato2="+90%"
  text2="Mejora en velocidad de carga promedio"

  
  dato3="100%"
  text3="Proyectos entregados a tiempo"

  />


  <CtaFinal />

  
</BaseLayout>