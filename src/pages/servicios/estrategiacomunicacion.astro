---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Estrategia de Comunicación" description="Diseñamos estrategias de comunicación que alinean tu mensaje, conectan con tu audiencia y posicionan tu marca con claridad y propósito.">

  <Headerservicios titulo="estrategia de" span="comunicación" ruta="estrategia de comunicación"
  imagen="https://i.pinimg.com/736x/9d/6c/cf/9d6ccf9d52f7c6163995c66ec5d46791.jpg"
  descripcion="Diseñamos estrategias de comunicación que alinean tu mensaje, conectan con tu audiencia y posicionan tu marca con claridad y propósito." />

  <Quehacemos descripcion="Construimos estrategias de comunicación integrales que definen cómo, cuándo y dónde habla tu marca. Cada decisión está respaldada por análisis, creatividad y un profundo entendimiento de tu audiencia."
  text1="Estrategia de marca y mensaje"
  text2="Planificación de contenidos y canales"
  text3="Comunicación interna y externa"
  text4="Análisis de audiencia y competencia"
  text5="Gestión de reputación y crisis"
  text6="Métricas, seguimiento y optimización"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Un ecosistema de comunicación coherente y efectivo que hace que tu marca hable con una sola voz en todos los canales y momentos."
  item1="01 — ESTRATEGIA DE MARCA"
  desc1="Definimos tu propósito, tono de voz, mensajes clave y posicionamiento diferenciador."
  item2="02 — PLAN DE CONTENIDOS"
  desc2="Calendario editorial estratégico con temas, formatos y canales alineados a tus objetivos."
  item3="03 — COMUNICACIÓN CORPORATIVA"
  desc3="Mensajes institucionales, comunicados y narrativa de marca para públicos externos e internos."
  item4="04 — GESTIÓN DE REDES SOCIALES"
  desc4="Estrategia, creación y publicación de contenido para construir comunidad y engagement."
  item5="05 — MANEJO DE CRISIS"
  desc5="Protocolos de respuesta y comunicación estratégica para proteger tu reputación en momentos críticos."
  item6="06 — MÉTRICAS Y REPORTES"
  desc6="Seguimiento de KPIs, análisis de resultados y optimización continua de la estrategia."
  />

  <Nuestrosprocesos
  text1="01 — DIAGNÓSTICO"
  desc1="Analizamos tu marca, audiencia, competencia y comunicación actual."
  text2="02 — ESTRATEGIA"
  desc2="Definimos objetivos, mensajes clave, canales y plan de acción."
  text3="03 — PLANIFICACIÓN"
  desc3="Desarrollamos el calendario editorial y los lineamientos de comunicación."
  text4="04 — EJECUCIÓN"
  desc4="Implementamos la estrategia con contenido, campañas y acciones concretas."
  text5="05 — OPTIMIZACIÓN"
  desc5="Medimos resultados, analizamos datos y ajustamos la estrategia en tiempo real."
  />

  <Casosdeexito
  caso1="Constructora Andina"
  text1="Estrategia de Comunicación Corporativa"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="Banco Progreso"
  text2="Plan de Contenidos y Redes Sociales"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="ONG Raíces"
  text3="Estrategia de Marca y Posicionamiento"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Retail Zona Norte"
  text4="Gestión de Crisis y Reputación"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+280%"
  text1="Más alcance orgánico para nuestros clientes"

  dato2="+75%"
  text2="Mejora en consistencia de marca promedio"

  dato3="100%"
  text3="Estrategias entregadas con resultados medibles"
  />

  <CtaFinal />

</BaseLayout>