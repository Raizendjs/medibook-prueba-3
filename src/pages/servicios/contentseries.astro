<BaseLayout title="Content Series" description="Creamos series de contenido estratégico que conectan con tu audiencia y posicionan tu marca.">
    
    <Headerservicios titulo="content" span="series" ruta="content series"
    imagen="https://i.pinimg.com/736x/9d/6c/cf/9d6ccf9d52f7c6163995c66ec5d46791.jpg"
    descripcion="Creamos series de contenido estratégico que conectan con tu audiencia y posicionan tu marca." /> 
    
    <Quehacemos descripcion="Desarrollamos series de contenido a medida que combinan narrativa, estrategia y producción. Nos enfocamos en la audiencia, el engagement y la conversión."
    text1="Contenido 100% personalizado"
    text2="Formatos modernos y escalables"
    text3="Orientado a resultados medibles"
    text4="Guiones y storytelling"
    text5="Producción audiovisual"
    text6="Distribución multicanal"
    src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
    />

  <Servicios descripcion="Soluciones integrales para que tu contenido no solo se vea increíble, sino que también genere resultados."
  item1="01 — SERIES DOCUMENTALES"
  desc1="Narrativas visuales de largo alance que construyen marca."
  item2="02 — PODCASTS Y ENTREVISTAS"
