---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Producción Audiovisual" description="Creamos piezas audiovisuales que comunican, emocionan y posicionan tu marca con producción de nivel profesional.">

  <Headerservicios titulo="producción" span="audiovisual" ruta="producción audiovisual"
  imagen="https://i.pinimg.com/736x/81/ee/ef/81eeefc0703cdcd2852db2619230696f.jpg"
  descripcion="Creamos piezas audiovisuales que comunican, emocionan y posicionan tu marca con producción de nivel profesional." />

  <Quehacemos descripcion="Producimos contenido audiovisual a medida para marcas que quieren destacar. Desde el concepto hasta la entrega final, nos encargamos de cada detalle para que tu historia se cuente de la mejor manera."
  text1="Producción de video profesional"
  text2="Dirección creativa y narrativa"
  text3="Edición y postproducción avanzada"
  text4="Motion graphics y animación"
  text5="Fotografía y dirección de arte"
  text6="Adaptación para todas las plataformas"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Piezas audiovisuales con propósito: cada proyecto está diseñado para conectar con tu audiencia y generar resultados reales para tu marca."
  item1="01 — VIDEO CORPORATIVO"
  desc1="Videos institucionales, de marca y presentaciones que generan confianza y credibilidad."
  item2="02 — SPOTS PUBLICITARIOS"
  desc2="Anuncios para TV, redes sociales y plataformas digitales con impacto y recordación."
  item3="03 — MOTION GRAPHICS"
  desc3="Animaciones y gráficos en movimiento que explican, venden y refuerzan tu identidad visual."
  item4="04 — VIDEO PARA REDES SOCIALES"
  desc4="Reels, stories y contenido vertical optimizado para el algoritmo y la atención del usuario."
  item5="05 — FOTOGRAFÍA COMERCIAL"
  desc5="Sesiones de foto profesional para productos, equipos, eventos y campañas de marca."
  item6="06 — POSTPRODUCCIÓN"
  desc6="Edición, colorización, sonorización y acabados que elevan cualquier pieza audiovisual."
  />

  <Nuestrosprocesos
  text1="01 — CONCEPTO"
  desc1="Definimos la idea, el mensaje y el enfoque creativo del proyecto."
  text2="02 — PREPRODUCCIÓN"
  desc2="Guión, storyboard, locaciones, casting y logística de rodaje."
  text3="03 — PRODUCCIÓN"
  desc3="Rodaje con equipos profesionales y dirección creativa en set."
  text4="04 — POSTPRODUCCIÓN"
  desc4="Edición, color, sonido, motion graphics y revisión de calidad."
  text5="05 — ENTREGA"
  desc5="Exportamos en los formatos necesarios para cada plataforma y canal."
  />

  <Casosdeexito
  caso1="Grupo Empresarial Orion"
  text1="Video Corporativo e Institucional"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="Nova Bebidas"
  text2="Spot Publicitario para Redes"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="Ecotek Solutions"
  text3="Motion Graphics y Branding en Video"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Clínica Vital"
  text4="Fotografía Comercial y Contenido Digital"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+350%"
  text1="Más visualizaciones para nuestros clientes"

  dato2="+80%"
  text2="Mejora en engagement con contenido en video"

  dato3="100%"
  text3="Proyectos entregados en tiempo y forma"
  />

  <CtaFinal />

</BaseLayout>