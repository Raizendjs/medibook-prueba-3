---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Dossiers Estratégicos" description="Creamos dossiers profesionales que presentan tu marca, proyecto o propuesta con claridad, impacto visual y argumentos que convencen.">

  <Headerservicios titulo="dossiers" span="estratégicos" ruta="dossiers estratégicos"
  imagen="https://i.pinimg.com/736x/dc/8e/be/dc8ebea44cd292080c3f0e45370690b8.jpg"
  descripcion="Creamos dossiers profesionales que presentan tu marca, proyecto o propuesta con claridad, impacto visual y argumentos que convencen." />

  <Quehacemos descripcion="Desarrollamos dossiers estratégicos que van más allá del diseño bonito. Cada documento está construido con una narrativa clara, estructura persuasiva y datos que respaldan tu propuesta de valor."
  text1="Narrativa estratégica y persuasiva"
  text2="Diseño editorial de alto impacto"
  text3="Estructura orientada a la decisión"
  text4="Redacción profesional y copywriting"
  text5="Adaptación a múltiples formatos y soportes"
  text6="Versiones digitales e imprimibles"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Documentos estratégicos que abren puertas, generan confianza y comunican el valor de tu marca o proyecto de forma irresistible."
  item1="01 — DOSSIER DE MARCA"
  desc1="Presentación integral de tu empresa: historia, valores, servicios y propuesta de valor."
  item2="02 — DOSSIER COMERCIAL"
  desc2="Documento de ventas diseñado para convencer a clientes, socios e inversores."
  item3="03 — DOSSIER DE PROYECTO"
  desc3="Presentación estructurada de iniciativas, propuestas y planes de negocio con foco estratégico."
  item4="04 — MEMORIA ANUAL"
  desc4="Informe de resultados, logros e impacto de tu organización con diseño editorial profesional."
  item5="05 — KIT DE PRENSA"
  desc5="Material listo para medios: ficha de empresa, bio, cifras clave e imágenes de marca."
  item6="06 — PRESENTACIONES EJECUTIVAS"
  desc6="Decks y presentaciones de alto nivel para reuniones, pitches y eventos corporativos."
  />

  <Nuestrosprocesos
  text1="01 — BRIEFING"
  desc1="Entendemos tu objetivo, audiencia y el mensaje que debe comunicar el dossier."
  text2="02 — ESTRUCTURA"
  desc2="Definimos la narrativa, el orden de contenidos y los argumentos clave."
  text3="03 — REDACCIÓN"
  desc3="Escribimos los textos con copywriting estratégico alineado a tu tono de marca."
  text4="04 — DISEÑO"
  desc4="Maquetamos el documento con diseño editorial de alto impacto y coherencia visual."
  text5="05 — ENTREGA"
  desc5="Entregamos en PDF interactivo, versión imprimible y formatos editables según necesites."
  />

  <Casosdeexito
  caso1="Grupo Inversiones Cóndor"
  text1="Dossier Comercial e Institucional"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="Startup Nexo Tech"
  text2="Dossier de Proyecto y Pitch Deck"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="Fundación Horizonte"
  text3="Memoria Anual y Kit de Prensa"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Arquitectura Forma"
  text4="Dossier de Marca y Portafolio"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+60%"
  text1="Más cierres comerciales tras presentar el dossier"

  dato2="+85%"
  text2="Mejora en percepción de marca ante clientes clave"

  dato3="100%"
  text3="Dossiers entregados en tiempo y con revisiones incluidas"
  />

  <CtaFinal />

</BaseLayout>