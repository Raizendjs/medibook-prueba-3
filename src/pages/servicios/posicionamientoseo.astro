  caso2="Ferretería Industrial Norte"
  text2="Posicionamiento Orgánico y SEO Técnico"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="Academia Digital Pro"
  text3="Estrategia de Contenido SEO y Link Building"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Inmobiliaria Vista Verde"
  text4="SEO On-Page y Generación de Leads Orgánicos"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+410%"
  text1="Más tráfico orgánico para nuestros clientes"

  dato2="+88%"
  text2="Mejora en posiciones de keywords objetivo"

  dato3="100%"
  text3="Clientes en primera página de Google"
  />

  <CtaFinal />

</BaseLayout>