---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Posicionamiento SEO" description="Te llevamos a los primeros lugares de Google con estrategias SEO basadas en datos, contenido y optimización técnica que generan tráfico real y sostenido.">

  <Headerservicios titulo="posicionamiento" span="seo" ruta="posicionamiento seo"
  imagen="https://www.valtx.pe/storage/uploads/que%20es%20el%20desarrollo%20de%20aplicaciones.png"
  descripcion="Te llevamos a los primeros lugares de Google con estrategias SEO basadas en datos, contenido y optimización técnica que generan tráfico real y sostenido." />

  <Quehacemos descripcion="Desarrollamos estrategias SEO integrales que combinan optimización técnica, contenido relevante y autoridad de dominio. Nuestro enfoque está en resultados medibles y crecimiento orgánico a largo plazo."
  text1="Auditoría y diagnóstico SEO completo"
  text2="Investigación y estrategia de keywords"
  text3="Optimización técnica on-page y off-page"
  text4="Contenido SEO y link building"
  text5="SEO local y Google Business Profile"
  text6="Reportes mensuales y seguimiento de posiciones"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Una estrategia SEO completa que mejora tu visibilidad en buscadores, atrae tráfico cualificado y convierte visitas en clientes de forma orgánica y sostenida."
  item1="01 — AUDITORÍA SEO"
  desc1="Análisis técnico completo de tu sitio para identificar errores, oportunidades y prioridades de mejora."
  item2="02 — SEO ON-PAGE"
  desc2="Optimización de títulos, metadatos, estructura, velocidad y contenido interno de tu sitio web."
  item3="03 — SEO TÉCNICO"
  desc3="Corrección de errores de rastreo, indexación, Core Web Vitals y arquitectura de URLs."
  item4="04 — LINK BUILDING"
  desc4="Construcción de autoridad de dominio mediante enlaces de calidad desde sitios relevantes y confiables."
  item5="05 — SEO LOCAL"
  desc5="Optimización para búsquedas locales y gestión de Google Business Profile para atraer clientes cercanos."
  item6="06 — REPORTES Y SEGUIMIENTO"
  desc6="Informes mensuales de posiciones, tráfico, conversiones y evolución de la estrategia SEO."
  />

  <Nuestrosprocesos
  text1="01 — AUDITORÍA"
  desc1="Analizamos tu sitio, competencia y oportunidades de posicionamiento en tu industria."
  text2="02 — ESTRATEGIA"
  desc2="Definimos keywords objetivo, prioridades técnicas y plan de contenidos SEO."
  text3="03 — OPTIMIZACIÓN"
  desc3="Implementamos mejoras técnicas, on-page y de contenido en tu sitio web."
  text4="04 — LINK BUILDING"
  desc4="Construimos autoridad con enlaces de calidad y presencia en directorios relevantes."
  text5="05 — SEGUIMIENTO"
  desc5="Monitoreamos posiciones, tráfico y resultados con reportes mensuales y ajustes continuos."
  />

  <Casosdeexito
  caso1="Clínica Dental Sonríe"
  text1="SEO Local y Google Business Profile"
