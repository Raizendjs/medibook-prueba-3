---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Transmisiones y Coberturas" description="Transmitimos y cubrimos tus eventos en vivo con producción profesional, para que cada momento llegue a tu audiencia sin importar dónde esté.">

  <Headerservicios titulo="transmisiones y" span="coberturas" ruta="transmisiones y coberturas"
  imagen="https://i.pinimg.com/736x/5a/80/29/5a80295a268a610b55785be68e5009d7.jpg"
  descripcion="Transmitimos y cubrimos tus eventos en vivo con producción profesional, para que cada momento llegue a tu audiencia sin importar dónde esté." />

  <Quehacemos descripcion="Gestionamos la producción completa de transmisiones en vivo y coberturas de eventos. Desde la logística técnica hasta la dirección creativa, nos encargamos de que cada transmisión sea impecable."
  text1="Transmisiones en vivo multiplataforma"
  text2="Cobertura audiovisual de eventos"
  text3="Dirección técnica y creativa en sitio"
  text4="Streaming a YouTube, Instagram y más"
  text5="Multicámara y producción en tiempo real"
  text6="Resumen y contenido post-evento"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Soluciones completas para que tus eventos lleguen más lejos y queden documentados con la calidad que tu marca merece."
  item1="01 — STREAMING EN VIVO"
  desc1="Transmisiones simultáneas a múltiples plataformas con estabilidad y calidad HD."
  item2="02 — COBERTURA DE EVENTOS"
  desc2="Documentación audiovisual completa de conferencias, lanzamientos y eventos corporativos."
  item3="03 — PRODUCCIÓN MULTICÁMARA"
  desc3="Dirección en tiempo real con múltiples cámaras para una experiencia dinámica y profesional."
  item4="04 — GRAFICAS Y OVERLAYS EN VIVO"
  desc4="Lower thirds, logos, tickers y elementos visuales en tiempo real que refuerzan tu marca."
  item5="05 — RESUMEN POST-EVENTO"
  desc5="Edición del mejor contenido del evento para redes sociales y archivo de marca."
  item6="06 — LOGÍSTICA Y SOPORTE TÉCNICO"
  desc6="Instalación de equipos, pruebas previas y soporte en sitio durante todo el evento."
  />

  <Nuestrosprocesos
  text1="01 — BRIEFING"
  desc1="Entendemos el evento, la audiencia y los objetivos de la transmisión."
  text2="02 — PLANIFICACIÓN"
  desc2="Definimos logística, equipos, plataformas y flujo de producción."
  text3="03 — MONTAJE"
  desc3="Instalación y prueba de equipos técnicos antes del evento."
  text4="04 — TRANSMISIÓN"
  desc4="Producción en vivo con dirección técnica y creativa en tiempo real."
  text5="05 — POST-EVENTO"
  desc5="Entregamos resumen editado y contenido listo para redes y archivo."
  />

  <Casosdeexito
  caso1="Summit Empresarial 2024"
  text1="Transmisión en Vivo Corporativa"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="Lanzamiento Nexo Brand"
  text2="Cobertura de Evento de Producto"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="TEDx Quito 2024"
  text3="Producción Multicámara en Vivo"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Congreso Salud Global"
  text4="Streaming Multiplataforma"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+10K"
  text1="Espectadores en vivo promedio por evento"

  dato2="+95%"
  text2="Uptime y estabilidad en transmisiones"

  dato3="100%"
  text3="Eventos cubiertos sin incidentes técnicos"
  />

  <CtaFinal />

</BaseLayout>