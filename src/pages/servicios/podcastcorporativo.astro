---
import BaseLayout from "../../layouts/BaseLayout.astro"
import Headerservicios from "../../components/Headerservicios.astro"
import Quehacemos from "../../components/Quehacemos.astro"
import Servicios from "../../components/Servicios.astro"
import Nuestrosprocesos from "../../components/Nuestrosprocesos.astro"
import Casosdeexito from "../../components/Casosdeexito.astro"
import Resultados from "../../components/Resultados.astro"
import CtaFinal from "../../components/CtaFinal.astro"
---



<BaseLayout title="Podcast Corporativo" description="Producimos tu podcast corporativo de principio a fin: grabación, edición y publicación con identidad de marca.">

  <Headerservicios titulo="podcast" span="corporativo" ruta="podcast corporativo"
  imagen="https://i.pinimg.com/736x/c3/77/c4/c377c4440afd83881a6e596a48050615.jpg"
  descripcion="Producimos tu podcast corporativo de principio a fin: grabación, edición y publicación con identidad de marca." />

  <Quehacemos descripcion="Creamos podcasts corporativos que posicionan tu marca como referente en tu industria. Nos encargamos de todo el proceso para que tú solo te preocupes por hablar."
  text1="Producción profesional end-to-end"
  text2="Identidad sonora personalizada"
  text3="Publicación en todas las plataformas"
  text4="Guiones y preparación de episodios"
  text5="Edición y postproducción de audio"
  text6="Estrategia y calendario editorial"
  src="https://www.youtube.com/embed/uXlWYZ022zU?si=dOfHWuSNOR4Kv1mu"
  />

  <Servicios descripcion="Todo lo que necesitas para lanzar y mantener un podcast corporativo que genere autoridad y conecte con tu audiencia."
  item1="01 — GRABACIÓN PROFESIONAL"
  desc1="Sesiones de grabación con equipos de alta calidad y dirección técnica."
  item2="02 — EDICIÓN Y POSTPRODUCCIÓN"
  desc2="Edición de audio, limpieza de ruido, música y efectos con identidad propia."
  item3="03 — IDENTIDAD SONORA"
  desc3="Intro, outro y cortinas musicales únicas que hacen reconocible tu podcast."
  item4="04 — PUBLICACIÓN MULTIPLATAFORMA"
  desc4="Subimos y optimizamos tus episodios en Spotify, Apple Podcasts, YouTube y más."
  item5="05 — GUIÓN Y PREPARACIÓN"
  desc5="Estructuramos cada episodio con guión, preguntas y flujo narrativo claro."
  item6="06 — ESTRATEGIA EDITORIAL"
  desc6="Planificación de temporadas, temas y calendario para publicación consistente."
  />

  <Nuestrosprocesos
  text1="01 — BRIEF"
  desc1="Definimos el concepto, audiencia y tono de tu podcast."
  text2="02 — PREPRODUCCIÓN"
  desc2="Creamos el guión, estructura y preparamos la sesión de grabación."
  text3="03 — GRABACIÓN"
  desc3="Sesión profesional con dirección técnica y dirección de contenido."
  text4="04 — EDICIÓN"
  desc4="Postproducción de audio, música, efectos y revisión de calidad."
  text5="05 — PUBLICACIÓN"
  desc5="Lanzamos el episodio en todas las plataformas y te acompañamos en el crecimiento."
  />

  <Casosdeexito
  caso1="Innova Corp"
  text1="Podcast de Liderazgo Empresarial"
  img1="https://i.pinimg.com/736x/d0/6b/94/d06b94c8065ff82e18b490baeef19609.jpg"

  caso2="Tech Latam"
  text2="Podcast de Tecnología e Innovación"
  img2="https://i.pinimg.com/736x/d8/91/fa/d891fa125a44487fab2a1dea1572df08.jpg"

  caso3="Finanzas Pro"
  text3="Podcast de Educación Financiera"
  img3="https://i.pinimg.com/736x/44/77/fb/4477fb5bd81a3b913035df4c786aeb86.jpg"

  caso4="Salud 360"
  text4="Podcast Corporativo de Bienestar"
  img4="https://i.pinimg.com/736x/7b/0b/49/7b0b498bdfdf8dce0728ae07bfc61208.jpg"
  />

  <Resultados
  dato1="+400%"
  text1="Más alcance orgánico para nuestros clientes"

  dato2="+90%"
  text2="Mejora en retención de oyentes promedio"

  dato3="100%"
  text3="Episodios entregados a tiempo"
  />

  <CtaFinal />

</BaseLayout>   