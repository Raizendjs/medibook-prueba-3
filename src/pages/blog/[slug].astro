---
import { getCollection, render, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import Callout from "../../components/mdx/Callout.astro";
import { resolvePath } from "../../utils/navigation";

/* =========================
   SLUGS
========================= */
export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { entry: post },
  }));
}

const { entry } = Astro.props;

/* =========================
   MDX SAFE RENDER
========================= */
let Content;
let headings = [];

try {
  const rendered = await render(entry);
  Content = rendered?.Content;
  headings = rendered?.headings ?? [];
} catch (err) {
  console.error("MDX ERROR:", err);
}

/* =========================
   AUTHOR SAFE LOAD
========================= */
let author;

try {
  if (entry?.data?.author) {
    author = await getEntry(entry.data.author);
  }
} catch (err) {
  console.error("AUTHOR ERROR:", err);
}

const authorName = author?.data?.name ?? "Zenix Author";
const authorRole = author?.data?.role ?? "Contributor";
const authorAvatar = author?.data?.avatar ?? "";

const authorInitials = authorName
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((p) => p[0])
  .join("")
  .toUpperCase();

/* =========================
   RELATED POSTS
========================= */
const allPosts = await getCollection("blog");

const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id)
  .map((p) => {
    const shared = (p.data.tags || []).filter((t) =>
      (entry.data.tags || []).includes(t)
    );

    return { ...p, sharedCount: shared.length };
  })
  .filter((p) => p.sharedCount > 0)
  .sort(
    (a, b) =>
      b.sharedCount - a.sharedCount ||
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  )
  .slice(0, 3);

const mdxComponents = { Callout };
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  type="article"
  publishedDate={entry.data.pubDate}
  modifiedDate={entry.data.updatedDate ?? entry.data.pubDate}
  author={authorName}
>
  <article class="py-24 md:py-32 bg-white dark:bg-[#09090b] relative overflow-hidden">

    <!-- Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary-500/10 dark:bg-primary-500/5 rounded-full blur-[100px] -z-10"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">

      <!-- HEADER -->
      <div class="mb-16 text-center max-w-4xl mx-auto">

        <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-slate-500 mb-6">

          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>

          <span class="w-1 h-1 rounded-full bg-slate-300"></span>

          <span class="flex items-center gap-2 text-slate-900 dark:text-slate-300">
            <span class="relative inline-flex h-6 w-6 items-center justify-center rounded-full bg-primary-100 text-[10px] font-bold text-primary-700">
              {authorInitials}
              {authorAvatar && (
                <img
                  src={authorAvatar}
                  class="absolute inset-0 w-full h-full rounded-full object-cover"
                />
              )}
            </span>
            {authorName}
          </span>

        </div>

        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 dark:text-white mb-8">
          {entry.data.title}
        </h1>

        <div class="flex flex-wrap justify-center gap-2">
          {entry.data.tags?.map((tag) => (
            <Badge variant="neutral">{tag}</Badge>
          ))}
        </div>
      </div>

      <div class="border-t border-slate-200 dark:border-slate-800 my-16"></div>

      <!-- GRID -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_minmax(auto,700px)_1fr] gap-12">

        <!-- LEFT -->
        <div class="hidden lg:block sticky top-24">
          <a href={resolvePath("/blog/")} class="text-sm font-bold text-slate-500 hover:text-blue-600">
            ← Back
          </a>
        </div>

        <!-- CONTENT -->
        <div class="prose prose-lg dark:prose-invert max-w-none w-full">

          {Content ? (
            <Content components={mdxComponents} />
          ) : (
            <div class="p-6 bg-red-100 text-red-700 rounded-lg">
              No se pudo renderizar el contenido MDX
            </div>
          )}

        </div>

        <!-- TOC -->
        <TableOfContents headings={headings} />

      </div>

      <!-- RELATED -->
      {relatedPosts.length > 0 && (
        <div class="mt-32 pt-16 border-t border-slate-200 dark:border-slate-800">

          <h3 class="text-2xl font-bold mb-8">Related Articles</h3>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map((post) => (
              <a href={resolvePath(`/blog/${post.id}`)} class="block">
                <div class="p-6 rounded-2xl glass-panel">
                  <h4 class="font-bold mb-2">{post.data.title}</h4>
                  <p class="text-sm text-slate-500 line-clamp-2">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>

        </div>
      )}

    </div>
  </article>
</BaseLayout>