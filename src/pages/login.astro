---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { REPOSITORY_URL } from '../config';
import { resolvePath } from '../utils/navigation';
import LoginForm from "../components/auth/LoginForm";
---

<BaseLayout title="Sign in" description="Preview the Zenix demo sign in form.">
  <section class="min-h-[calc(100vh-4rem)] bg-slate-50 py-16 dark:bg-[#09090b] md:py-24">
    
    <div class="container h-auto mx-auto sm:flex-row lg:flex items-center justify-center max-w-6xl grid-cols-1 gap-12 px-4 lg:grid-cols-[1fr_460px]">

      <!-- LEFT -->

      
      <div class="max-w-2xl">

        <p class="mb-4 text-sm mt-20 font-bold uppercase text-primary-600 dark:text-primary-400">
          Acceso de clientes
        </p>

        <h1 class="mb-6  text-4xl font-extrabold text-slate-900 dark:text-white md:text-6xl">
         inicia sesión  en <span class="text-blue-600 uppercase">medibook</span> para poder agendar tu espacion medico.
        </h1>

        <p class="text-lg text-slate-600 dark:text-slate-400">
          Inicia sesión para acceder a tu dashboard y consultar tu estado de conexión, monitorear la actividad de tu equipo en tiempo real y mantener el control de toda la información importante desde un solo lugar.

        </p>

        <div class="mt-8 lg:flex flex-row lg:w-full  gap-8">
          <a href="/"><button  class="bg-blue-600 m-auto text-white py-6 lg:px-6 px-15   rounded-2xl shadow-2xl flex  gap-3 "> <slot><svg class="w-6 h-6 text-white dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M11 4.717c-2.286-.58-4.16-.756-7.045-.71A1.99 1.99 0 0 0 2 6v11c0 1.133.934 2.022 2.044 2.007 2.759-.038 4.5.16 6.956.791V4.717Zm2 15.081c2.456-.631 4.198-.829 6.956-.791A2.013 2.013 0 0 0 22 16.999V6a1.99 1.99 0 0 0-1.955-1.993c-2.885-.046-4.76.13-7.045.71v15.081Z" clip-rule="evenodd"/>
          </svg>
          </slot>Regitrate en medibook</button></a>
          

          <a href="/signup/"><button  class="bg-gray-100  m-auto font-semibold mt-5 lg:mt-0 border-gray-400 border-3 text-stone-800 py-6 px-14 rounded-2xl shadow-2xl flex  gap-3"> <slot><svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4 12 8-8 8 8M6 10.5V19a1 1 0 0 0 1 1h3v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h3a1 1 0 0 0 1-1v-8.5"/>
          </svg>
          
          </slot>Regitrate en medibook</button></a>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="glass-panel rounded-2xl p-6 shadow-xl mt-20 sm:p-8">
<div class="mb-6 rounded-xl border border-primary-200 bg-primary-50 px-4 py-3 text-sm text-primary-800 dark:border-primary-900/60 dark:bg-primary-950/40 dark:text-primary-200">
          inicio de seccion con tu cuenta de google o con tu correo electronico y contraseña.
        </div>


        <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">
          iniciar seccion
        </h2>
        

        <!-- 🔥 AQUÍ VA TODO EL LOGIN REAL -->
        <LoginForm client:load />
<br>
        

      </div>
      
    </div>
  </section>
</BaseLayout>
